# Cổng server
PORT=8080

# Kết nối MySQL — dùng 1 trong 2 cách:
# Cách A: DATABASE_URL đầy đủ
DATABASE_URL=mysql://user:password@host:3306/procureos
# Cách B: biến rời
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=procureos

# JWT
JWT_SECRET=doi-chuoi-bi-mat-nay
JWT_EXPIRES_IN=7d

# Admin mặc định (tạo tự động lần đầu nếu bảng users trống)
ADMIN_EMAIL=admin@garena.vn
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# Domain email được phép đăng ký
ALLOWED_DOMAIN=garena.vn
