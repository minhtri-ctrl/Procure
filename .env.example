# Cổng server
PORT=8080

# Kết nối MySQL — dùng 1 trong 2 cách:
# Cách A: DATABASE_URL đầy đủ
DATABASE_URL=mysql://user:password@host:3306/procureos
# Cách B: biến rời (thay bằng host DB thật của bạn)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=procureos

# JWT
JWT_SECRET=doi-chuoi-bi-mat-nay
JWT_EXPIRES_IN=7d

# Admin mặc định (tạo tự động lần đầu nếu bảng users trống)
ADMIN_EMAIL=admin@garena.vn
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# Domain email được phép đăng ký
ALLOWED_DOMAIN=garena.vn

# ---------------------------------------------------------------------
# Backup MySQL -> Google Sheets (tuỳ chọn — bỏ trống để tắt hoàn toàn)
# ---------------------------------------------------------------------
# ID của Google Sheet đích (lấy từ URL, không phải link đầy đủ)
GOOGLE_SHEET_ID=
# Local dev: đường dẫn tới file service account key JSON (KHÔNG commit file này)
GOOGLE_APPLICATION_CREDENTIALS_FILE=secrets/your-service-account-key.json
# Production (Demo System không có filesystem riêng để đặt file secrets/): set toàn bộ
# nội dung file JSON key, encode base64, làm giá trị biến này qua deploy env config.
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON=<base64 của file JSON key>
# Chu kỳ cron đồng bộ (phút)
BACKUP_INTERVAL_MINUTES=10
